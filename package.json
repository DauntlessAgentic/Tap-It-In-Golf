{
  "name": "golfcast-calendar",
  "version": "0.1.0",
  "private": true,
  "description": "Writes weather-scored golf tee-time windows for The Meadows G&CC into a dedicated Google Calendar.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "sync:golfcast": "tsx src/index.ts sync",
    "auth:google": "tsx src/auth/bootstrapOAuth.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
